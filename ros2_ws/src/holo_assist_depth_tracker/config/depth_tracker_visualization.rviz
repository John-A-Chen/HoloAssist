    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Bench Plane Marker
      Namespaces:
        holoassist_bench_plane: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /holoassist/perception/bench_plane_marker
      Value: true
    - Class: rviz_default_plugins/Marker
