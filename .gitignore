# ROS workspace build artifacts
/ros2_ws/build/
/ros2_ws/install/
/ros2_ws/log/

# Keep ROS source tree tracked
!/ros2_ws/
!/ros2_ws/src/
!/ros2_ws/src/**

# docker workspaces / bind mounts
# Ignore built workspace artifacts, but keep source folders visible
/docker/**/build/
/docker/**/install/
/docker/**/log/
/docker/**/ws/build/
/docker/**/ws/install/
/docker/**/ws/log/

# ROS tooling caches
.ros/
.rosinstall
.rosinstall.bak
.rosinstall.catkin
*.repos.bak

# VS Code (keep settings, ignore caches)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/c_cpp_properties.json
.vscode/*.db
.vscode/*.db-shm
.vscode/*.db-wal
.vscode/ipch/

# JetBrains
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Bags
*.db3
*.mcap
bags/

# OS / editor junk
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Large sim artefacts (optional, if they appear)
.gazebo/
.ignition/

# Frontend
holoassist-dashboard/node_modules/
holoassist-dashboard/dist/
holoassist-dashboard/.vite/

# Unity (track source-of-truth files, ignore generated/local noise)
Unity/**/[Ll]ibrary/
Unity/**/[Tt]emp/
Unity/**/[Oo]bj/
Unity/**/[Bb]uild/
Unity/**/[Bb]uilds/
Unity/**/[Ll]ogs/
Unity/**/[Uu]ser[Ss]ettings/
Unity/**/.vscode/
Unity/**/.vs/
Unity/**/.idea/
Unity/**/.gradle/
Unity/**/.utmp/
Unity/**/.plastic/
Unity/**/MemoryCaptures/
Unity/**/Recordings/
Unity/**/*_BurstDebugInformation_DoNotShip/
Unity/**/*_BackUpThisFolder_ButDontShipItWithYourGame/
Unity/**/*.csproj
Unity/**/*.sln
Unity/**/*.suo
Unity/**/*.tmp
Unity/**/*.user
Unity/**/*.userprefs
Unity/**/*.pidb
Unity/**/*.booproj
Unity/**/*.svd
